{
  "expo": {
    "name": "jiohotstar-clone",
    "slug": "jiohotstar-clone",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "jiohotstarclone",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "com.jiohotstarclone.app"
    },
    "android": {
      "package": "com.jiohotstarclone.app",
      "adaptiveIcon": {
        "backgroundColor": "#6B2D8B",
        "foregroundImage": "./assets/images/icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#201240",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7e5a5e77-b53d-4761-b15e-e1b89ace3709"
      }
    }
  }
}
