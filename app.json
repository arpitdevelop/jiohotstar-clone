{
  "expo": {
    "name": "jiohotstar-clone",
    "slug": "jiohotstar-clone",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "jiohotstarclone",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "com.jiohotstarclone.app"
    },
    "android": {
      "package": "com.jiohotstarclone.app",
      "adaptiveIcon": {
        "backgroundColor": "#6B2D8B",
        "foregroundImage": "./assets/images/icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "PORTRAIT_UP"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#201240",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-image",
      [
        "expo-alternate-app-icons",
        [
          {
            "name": "DarkIcon",
            "ios": "./assets/app-icons/dark-icon.png",
            "android": {
              "foregroundImage": "./assets/app-icons/dark-icon.png",
              "backgroundColor": "#0A0F17"
            }
          },
          {
            "name": "DiwaliIcon",
            "ios": "./assets/app-icons/diwali-icon.png",
            "android": {
              "foregroundImage": "./assets/app-icons/diwali-icon.png",
              "backgroundColor": "#201240"
            }
          },
          {
            "name": "GoldIcon",
            "ios": "./assets/app-icons/gold-icon.png",
            "android": {
              "foregroundImage": "./assets/app-icons/gold-icon.png",
              "backgroundColor": "#120A24"
            }
          },
          {
            "name": "HoliIcon",
            "ios": "./assets/app-icons/holi-icon.png",
            "android": {
              "foregroundImage": "./assets/app-icons/holi-icon.png",
              "backgroundColor": "#170C30"
            }
          },
          {
            "name": "OriginalIcon",
            "ios": "./assets/app-icons/original-icon.png",
            "android": {
              "foregroundImage": "./assets/app-icons/original-icon.png",
              "backgroundColor": "#6B2D8B"
            }
          }
        ]
      ],
      "expo-video",
      [
        "@sentry/react-native",
        {
          "organization": "arpit-w9",
          "project": "react-native"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "arpit-w9"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7e5a5e77-b53d-4761-b15e-e1b89ace3709"
      }
    }
  }
}
